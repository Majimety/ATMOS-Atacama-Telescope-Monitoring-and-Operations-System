# ATMOS Environment Variables
# Copy this file to .env and fill in real values
# Generate secrets: openssl rand -hex 32

# ── Server ────────────────────────────────────────────────────

# JWT secret — MUST change in production
ATMOS_SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32

# Token expiry in minutes (default: 60)
ATMOS_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Domain & TLS (required for Docker production stack) ───────
# Your public domain — used by Traefik for routing + TLS
DOMAIN=atmos.example.com

# Let's Encrypt notification email
ACME_EMAIL=admin@example.com

# Traefik dashboard basic auth (htpasswd format)
# Generate: htpasswd -nb admin yourpassword
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$10$$changeThisHash

# ── InfluxDB ──────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=atmos-dev-token-change-in-production
INFLUX_ORG=atmos
INFLUX_BUCKET=telemetry
INFLUX_BUCKET_TELEMETRY=atmos_telemetry
INFLUX_BUCKET_ATMOSPHERE=atmos_atmosphere
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=change-this-influx-password

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change-this-redis-password

# ── Weather API ───────────────────────────────────────────────
# Open-Meteo ใช้ได้ฟรี ไม่ต้อง API key
# เว้นว่างไว้ = ใช้ simulation fallback
# OPEN_METEO_OVERRIDE_URL=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production: ใส่ domain จริง เช่น https://atmos.example.com
ATMOS_CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
