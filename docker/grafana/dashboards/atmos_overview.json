{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ATMOS — Atacama Telescope real-time telemetry overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Array Health",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 55 }
            ]
          },
          "unit": "none",
          "min": 0, "max": 66
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Online Dishes",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"array_health\" and r._field == \"online_count\")\n  |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "K"
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Avg Tsys",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"array_health\" and r._field == \"avg_tsys_k\")\n  |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 3.0 }
            ]
          },
          "unit": "mm",
          "decimals": 2
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "PWV",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"atmosphere\" and r._field == \"pwv_mm\")\n  |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
      "fieldConfig": {
        "defaults": { "unit": "K", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list" } },
      "title": "Avg Tsys — 1h history",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"array_health\" and r._field == \"avg_tsys_k\")\n  |> aggregateWindow(every: 30s, fn: mean)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
      "fieldConfig": {
        "defaults": { "unit": "mm", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 11,
      "title": "PWV — 1h history",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "InfluxDB-ATMOS" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"atmosphere\" and r._field == \"pwv_mm\")\n  |> aggregateWindow(every: 30s, fn: mean)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["atmos", "telescope", "alma"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ATMOS — Telemetry Overview",
  "uid": "atmos-overview-v1",
  "version": 1
}
